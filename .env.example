# Copy to `.env` for local reference. Never commit real secrets.
# Vite (client) — only non-secret public keys:
# VITE_SUPABASE_URL=
# VITE_SUPABASE_PUBLISHABLE_KEY=

# Phone SMS OTP is sent by Supabase Auth (not this repo). Configure in:
# Dashboard → Authentication → Providers → Phone (SMS provider / template).
# See: https://supabase.com/docs/guides/auth/phone-login
